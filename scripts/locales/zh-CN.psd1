@{
  Locale = "zh-CN"
  Templates = @{
    # =========================================================================
    # 译者指南：
    # =========================================================================
    # 1. 技术标签：[*], [+], [-], [!] 
    #    - 这些是日志前缀。请保留在行首。
    #    - 请勿翻译或删除它们。
    #
    # 2. 占位符：{0}, {1}, {2}...
    #    - 这些是动态数据（模组名称、数字、路径）。
    #    - 强制：必须保留在翻译后的字符串中。
    #    - 可以根据语法调整它们的顺序。
    #
    # 3. 技术标签：[core], [layer], [tier]
    #    - 模组类别。
    #    - 重要：若要统一翻译这些标签，请修改下方的 'Substrings' 区域。
    #    - 请勿在 'Templates' 内部修改它们，除非某行需要特定翻译。
    #
    # 4. 输入提示：<KEY_...>
    #    - 技术标签，按键值由代码填入。
    #    - 请勿修改标签名（例如 <KEY_RETRY_HINT>）。
    #
    # 5. 特殊字符：
    #    - `n  : 换行符（PowerShell 格式）。
    #    - \" : 字符串内的转义引号。
    #
    # 6. 调试/详细日志字符串：
    #    - Write-Verbose 消息（仅限调试）故意保持为英文。
    #    - 它们不计入 tools/Check-Localization.py 的翻译覆盖率。
    # =========================================================================

